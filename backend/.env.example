# PostgreSQL Database Configuration
# Replace with your actual database credentials
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/auth_db

# JWT Secret Key for token signing
# Generate a strong random key for production using: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-secret-key-here-change-in-production

# Google OAuth Configuration
# Get this from Google Cloud Console: https://console.cloud.google.com/
# Steps:
# 1. Create a new project
# 2. Enable Google+ API
# 3. Create OAuth 2.0 Web Client credentials
# 4. Add authorized origins (e.g., http://localhost:5500)
# 5. Copy the Client ID here
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
