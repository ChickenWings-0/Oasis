# Video Generation Configuration Example
# Copy this file to .env.local and fill in your values

# =============================================================================
# HuggingFace Configuration (Required for AI Models)
# =============================================================================

# Your HuggingFace API token
# Get it from: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Optional: Custom HuggingFace API endpoint
# HF_API_URL=https://api-inference.huggingface.co/models

# =============================================================================
# Video Generation Configuration
# =============================================================================

# Default video generation model
# Options: 'huggingface', 'local_diffusers', or leave empty for simple text-based
NEXT_PUBLIC_VIDEO_MODEL=huggingface

# HuggingFace model to use by default
# Options:
#   - cerspense/zeroscope_v2_XL (highest quality, slowest)
#   - cerspense/zeroscope_v2_576w (balance of quality/speed)
#   - damo-vilab/text-to-video-ms-1.7b (fastest)
NEXT_PUBLIC_VIDEO_MODEL_ID=cerspense/zeroscope_v2_XL

# Number of inference steps (higher = better quality but slower)
# Recommended: 20-30
NEXT_PUBLIC_VIDEO_GENERATION_STEPS=25

# =============================================================================
# Output Configuration
# =============================================================================

# Timeout for video generation requests in milliseconds
# Default: 300000 (5 minutes)
VIDEO_GENERATION_TIMEOUT=300000

# Maximum video duration in seconds
MAX_VIDEO_DURATION=60

# Minimum video duration in seconds
MIN_VIDEO_DURATION=5

# =============================================================================
# Performance Configuration
# =============================================================================

# Enable video generation request queue (for production)
# ENABLE_VIDEO_QUEUE=false

# Maximum concurrent video generation requests
# MAX_CONCURRENT_VIDEOS=2

# =============================================================================
# Development Configuration
# =============================================================================

# Enable verbose logging
# DEBUG=false

# Enable API request logging
# LOG_API_REQUESTS=false
