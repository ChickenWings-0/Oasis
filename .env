# =============================================================================
# DEVELOPMENT ENVIRONMENT FILE - DO NOT COMMIT TO REPOSITORY
# =============================================================================

# Environment Setting
ENVIRONMENT=development
DEBUG=true

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database_name
# Note: Special characters in password must be URL-encoded (@ = %40)
DATABASE_URL=postgresql://postgres:dhruv%402008@localhost:5432/auth_db
PROJECT_DATABASE_URL=postgresql://postgres:dhruv%402008@localhost:5432/project_service_db
DATABASE_ECHO=false
LOG_LEVEL=INFO

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
# Secret key for signing JWT tokens (CHANGE IN PRODUCTION!)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-dev-secret-key-change-in-production-12345
JWT_SECRET_KEY=your-dev-secret-key-change-in-production-12345
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# =============================================================================
# GOOGLE OAUTH 2.0
# =============================================================================
# Get from Google Cloud Console: https://console.cloud.google.com/
# For local testing, you can use this placeholder or any valid format
GOOGLE_CLIENT_ID=879602255278-o0qm0guucgta1vj46696u04mjgd8e05l.apps.googleusercontent.com

# =============================================================================
# SERVICE CONFIGURATION
# =============================================================================
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8002

# CORS Configuration
CORS_ORIGINS=["*"]

# Database Pooling (project_service)
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
